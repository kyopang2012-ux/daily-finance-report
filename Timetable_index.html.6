<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LPS 老師時間表查詢系統 2025-2026</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#f0f2f7;--cd:#fff;--p:#2563eb;--pl:#eff4ff;--pd:#1e40af;--g:#059669;--gl:#d1fae5;--gd:#065f46;--o:#f59e0b;--ol:#fef3c7;--od:#92400e;--v:#7c3aed;--vl:#ede9fe;--vd:#5b21b6;--t:#0f172a;--ts:#64748b;--tm:#94a3b8;--bd:#e2e8f0;--sh:0 1px 3px rgba(0,0,0,.05);--shm:0 4px 14px rgba(0,0,0,.07);--shl:0 8px 30px rgba(0,0,0,.1)}
body{font-family:'Noto Sans TC',system-ui,sans-serif;background:var(--bg);color:var(--t);min-height:100vh;-webkit-font-smoothing:antialiased}
.hd{background:linear-gradient(135deg,#1e3a8a 0%,#2563eb 60%,#3b82f6 100%);color:#fff;padding:18px 0 0;text-align:center;position:sticky;top:0;z-index:100;box-shadow:0 4px 24px rgba(30,64,175,.3)}
.hd h1{font-size:1.25rem;font-weight:700}.hd .sub{font-size:.76rem;opacity:.6;margin-top:1px}
.tabs{display:flex;justify-content:center;gap:2px;margin-top:10px;flex-wrap:wrap}
.tab{padding:7px 14px;border:none;background:rgba(255,255,255,.1);color:rgba(255,255,255,.8);font-size:.78rem;font-weight:500;cursor:pointer;border-radius:10px 10px 0 0;transition:all .2s;font-family:inherit;white-space:nowrap}
.tab.on{background:#fff;color:var(--p);font-weight:600}.tab:hover:not(.on){background:rgba(255,255,255,.2)}
.wrap{max-width:1400px;margin:0 auto;padding:14px 12px 80px}
.pnl{display:none}.pnl.on{display:block}
.cd{background:var(--cd);border-radius:12px;box-shadow:var(--sh);padding:16px 18px;margin-bottom:12px;border:1px solid var(--bd)}
.ct{font-size:.9rem;font-weight:600;margin-bottom:10px;display:flex;align-items:center;gap:6px}
.stp{display:flex;gap:0;margin-bottom:10px;flex-wrap:wrap}
.st{display:flex;align-items:center;gap:5px;padding:6px 12px;background:#f8fafc;border:1px solid var(--bd);font-size:.72rem;font-weight:500;color:var(--ts)}
.st:first-child{border-radius:6px 0 0 6px}.st:last-child{border-radius:0 6px 6px 0}
.st .n{width:18px;height:18px;border-radius:50%;background:var(--bd);color:#fff;display:flex;align-items:center;justify-content:center;font-size:.62rem;font-weight:700}
.st.done .n{background:var(--g)}.st.on{background:var(--pl);border-color:var(--p);color:var(--pd)}.st.on .n{background:var(--p)}
.sb{position:relative;margin-bottom:7px}
.sb input{width:100%;padding:8px 12px 8px 32px;border:1.5px solid var(--bd);border-radius:8px;font-size:.82rem;font-family:inherit;outline:none;transition:all .2s;background:#fafbfc}
.sb input:focus{border-color:var(--p);box-shadow:0 0 0 3px rgba(37,99,235,.08);background:#fff}
.sb .ic{position:absolute;left:9px;top:50%;transform:translateY(-50%);color:var(--tm);font-size:.82rem}
.dd{position:absolute;top:calc(100% + 2px);left:0;right:0;background:#fff;border:1.5px solid var(--bd);border-radius:8px;max-height:230px;overflow-y:auto;z-index:50;box-shadow:var(--shl);display:none}
.dd.show{display:block}
.di{padding:7px 12px;cursor:pointer;font-size:.8rem;transition:background .1s;display:flex;justify-content:space-between}.di:hover{background:var(--pl)}.di .c{color:var(--tm);font-size:.7rem}
.chips{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:7px;min-height:20px}
.chip{display:inline-flex;align-items:center;gap:3px;padding:3px 9px;border-radius:18px;font-size:.74rem;font-weight:500;animation:ci .2s ease}
.chip-p{background:var(--pl);color:var(--pd)}.chip-v{background:var(--vl);color:var(--vd)}
@keyframes ci{from{transform:scale(.85);opacity:0}}
.chip .x{cursor:pointer;width:14px;height:14px;display:flex;align-items:center;justify-content:center;border-radius:50%;background:rgba(0,0,0,.07);font-size:.56rem}.chip .x:hover{background:rgba(0,0,0,.16)}
.br{display:flex;gap:4px;flex-wrap:wrap}
.tb{padding:5px 13px;border:1.5px solid var(--bd);background:#fff;border-radius:6px;cursor:pointer;font-size:.78rem;font-weight:500;font-family:inherit;transition:all .15s;user-select:none}
.tb.on{border-color:var(--p);background:var(--pl);color:var(--pd)}.tb:hover:not(.on){border-color:#cbd5e1;background:#f8fafc}.tb-sm{padding:3px 9px;font-size:.72rem}
.fg{display:flex;flex-direction:column;gap:3px}.fg label{font-size:.68rem;font-weight:600;color:var(--ts);text-transform:uppercase;letter-spacing:.3px}
.fg select,.fg input[type=text],.fg input[type=email],.fg input[type=date]{padding:7px 9px;border:1.5px solid var(--bd);border-radius:7px;font-size:.82rem;font-family:inherit;outline:none;background:#fff;min-width:75px}.fg select:focus,.fg input:focus{border-color:var(--p)}
.fr{display:flex;gap:9px;flex-wrap:wrap;align-items:flex-end}
.bp{padding:7px 18px;background:var(--p);color:#fff;border:none;border-radius:7px;font-size:.82rem;font-weight:600;cursor:pointer;font-family:inherit;box-shadow:0 2px 6px rgba(37,99,235,.2)}.bp:hover{background:var(--pd)}
.bg{padding:7px 18px;background:var(--g);color:#fff;border:none;border-radius:7px;font-size:.82rem;font-weight:600;cursor:pointer;font-family:inherit}.bg:hover{background:#047857}
.bv{padding:7px 18px;background:var(--v);color:#fff;border:none;border-radius:7px;font-size:.82rem;font-weight:600;cursor:pointer;font-family:inherit}.bv:hover{background:#6d28d9}
.bwa{padding:7px 18px;background:#25D366;color:#fff;border:none;border-radius:7px;font-size:.82rem;font-weight:600;cursor:pointer;font-family:inherit;display:inline-flex;align-items:center;gap:5px}.bwa:hover{background:#1fb855}
.sub-tabs{display:flex;gap:0;margin-bottom:12px}
.sub-tab{flex:1;padding:9px;border:1.5px solid var(--bd);background:#f8fafc;text-align:center;cursor:pointer;font-size:.82rem;font-weight:500;font-family:inherit;transition:all .2s}
.sub-tab:first-child{border-radius:8px 0 0 8px}.sub-tab:last-child{border-radius:0 8px 8px 0}
.sub-tab.on{background:var(--vl);border-color:var(--v);color:var(--vd);font-weight:600}
.sub-pnl{display:none}.sub-pnl.on{display:block}
.tw{overflow-x:auto;margin-top:8px;border-radius:8px;border:1px solid var(--bd)}
.tt{width:100%;border-collapse:collapse;font-size:.74rem}
.tt th,.tt td{padding:5px 3px;text-align:center;border:1px solid #e5e9ef}
.tt thead th{background:#f1f5f9;font-weight:600;color:var(--ts);font-size:.68rem;position:sticky;top:0;z-index:2}
.tt .sk{text-align:left;position:sticky;left:0;background:#fff;font-weight:500;min-width:72px;z-index:3;border-right:2px solid var(--bd);font-size:.72rem}
.tt thead .sk{background:#f1f5f9;z-index:4}
.cf{background:var(--gl)!important;color:var(--gd)!important;font-weight:600}
.cb{color:var(--ts);font-size:.66rem;line-height:1.2}
.cc{background:#6ee7b7!important;color:#064e3b!important;font-weight:700}
/* Side-by-side timetables */
.tt-pair{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:12px 0}
@media(max-width:900px){.tt-pair{grid-template-columns:1fr}}
.tt-pair-item{min-width:0}
.tt-pair-label{font-size:.88rem;font-weight:700;margin-bottom:6px;padding:6px 12px;border-radius:8px;display:flex;align-items:center;gap:6px}
.tt-pair-label.la{background:#fff7ed;color:#c2410c;border:1px solid #fed7aa}
.tt-pair-label.lb{background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe}
.tt-pair-label .hl-note{font-size:.7rem;font-weight:400;margin-left:auto;opacity:.7}
/* Formal TT */
.ftb-wrap{overflow-x:auto;border-radius:8px;box-shadow:0 1px 6px rgba(0,0,0,.06)}
.ftb{width:100%;min-width:480px;border-collapse:collapse;font-size:.72rem;background:#fff}
.ftb th,.ftb td{border:1px solid #bbb;padding:4px 2px;text-align:center;vertical-align:middle}
.ftb thead th{background:#f5f5f5;font-weight:700;font-size:.74rem;color:#333;padding:7px 2px}
.ftb thead th.corner{font-size:.68rem;min-width:68px}
.ftb .tc{background:#fafafa;font-size:.66rem;color:#666;font-weight:500;white-space:nowrap;min-width:68px}
.ftb .brk td{background:#f0f0f0;color:#999;font-weight:500;font-size:.72rem;letter-spacing:2px}
.ftb .lch td{background:#e8e8e8;color:#777;font-weight:600;font-size:.78rem;letter-spacing:3px}
.ftb .mrn td{color:#cc3333;font-weight:500;font-size:.68rem}
.ftb .asm td{color:#cc3333;font-weight:500;font-size:.72rem}
.ftb .lc{padding:2px 1px;min-height:36px;vertical-align:middle;line-height:1.3}
.ftb .lc .su{font-weight:600;font-size:.74rem;color:#333}
.ftb .lc .cl{font-size:.68rem;color:#555}
.ftb .lc .rm{font-size:.62rem;color:#999}
.ftb .ec{color:#ddd;font-size:.7rem}
.ftb .hl{background:#fff0f0!important}.ftb .hl .su,.ftb .hl .cl,.ftb .hl .rm{color:#cc0000!important;font-weight:700!important}
/* Swap selection for WA */
.sw-sel{border:2px solid transparent;transition:border-color .15s;cursor:pointer;position:relative}
.sw-sel:hover{border-color:var(--p)}
.sw-sel.chosen{border-color:#25D366;background:#f0fdf4}
.sw-sel .check{position:absolute;top:8px;right:10px;width:22px;height:22px;border-radius:50%;border:2px solid var(--bd);display:flex;align-items:center;justify-content:center;font-size:.7rem;color:#fff;transition:all .15s}
.sw-sel.chosen .check{background:#25D366;border-color:#25D366}
/* Generic */
.stb{width:100%;border-collapse:collapse;font-size:.78rem;margin-top:6px}
.stb th,.stb td{padding:6px 8px;border:1px solid #eef1f6;text-align:left}
.stb thead th{background:#f1f5f9;font-weight:600;color:var(--ts);position:sticky;top:0}
.stb tbody tr:hover{background:var(--pl)}.stb tbody tr:nth-child(even){background:#fafbfd}
.bn{padding:9px 13px;border-radius:8px;font-size:.8rem;font-weight:500;margin-bottom:10px;display:flex;align-items:center;gap:6px;line-height:1.5}.bn b{font-weight:700}
.bn-g{background:var(--gl);border:1px solid #a7f3d0;color:var(--gd)}.bn-b{background:#dbeafe;border:1px solid #93c5fd;color:#1e40af}
.bn-o{background:var(--ol);border:1px solid #fcd34d;color:var(--od)}.bn-v{background:var(--vl);border:1px solid #c4b5fd;color:var(--vd)}
.nr{text-align:center;color:var(--tm);padding:32px 0;font-size:.84rem}.nr .em{font-size:1.8rem;display:block;margin-bottom:4px}
.sw-list{display:flex;flex-direction:column;gap:7px;margin-top:8px}
.sw{background:#fff;border:1.5px solid var(--bd);border-radius:10px;padding:12px 14px;padding-right:45px;animation:fu .25s ease;transition:all .2s;position:relative;cursor:pointer;}
.sw:hover{border-color:var(--p);box-shadow:var(--shm)}
.sw.selected{border-color:var(--p);background:var(--pl)}
.sw-chk{position:absolute;top:50%;right:15px;transform:translateY(-50%);width:22px;height:22px;border-radius:5px;border:2px solid var(--bd);display:flex;align-items:center;justify-content:center;color:transparent;font-size:1rem;transition:.15s;background:#fff;font-weight:700}
.sw.selected .sw-chk{background:var(--p);border-color:var(--p);color:#fff}
@keyframes fu{from{opacity:0;transform:translateY(5px)}}
.sw-top{display:flex;align-items:center;gap:6px;flex-wrap:wrap;margin-bottom:4px}
.sw-badge{display:inline-flex;align-items:center;gap:3px;padding:3px 10px;border-radius:18px;font-size:.72rem;font-weight:600;white-space:nowrap}
.sw-from{background:#fef3c7;color:#92400e}.sw-arr{font-size:1.1rem;color:var(--tm)}.sw-to{background:#dbeafe;color:#1e40af}
.sw-body{font-size:.76rem;color:var(--ts);line-height:1.6;display:grid;grid-template-columns:1fr 1fr;gap:2px 14px}.sw-body strong{color:var(--t)}
@media(max-width:640px){.sw-body{grid-template-columns:1fr}}
.cfg{display:grid;grid-template-columns:repeat(auto-fill,minmax(100px,1fr));gap:5px;margin-top:8px}
.cfg-i{background:var(--gl);border:1px solid #a7f3d0;border-radius:7px;padding:8px 6px;text-align:center;font-size:.78rem;font-weight:600;color:var(--gd);animation:fu .2s ease}.cfg-i .d{font-size:.66rem;font-weight:400;color:#34d399;margin-top:1px}
.sa-card{background:#fff;border:1.5px solid var(--bd);border-radius:10px;padding:12px 14px;margin-bottom:8px;animation:fu .25s ease}
.sa-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;flex-wrap:wrap;gap:4px}
.sa-head .lbl{font-size:.84rem;font-weight:700}.sa-head .badge{padding:3px 9px;border-radius:18px;font-size:.7rem;font-weight:600}
.sa-free-list{display:flex;flex-wrap:wrap;gap:3px;margin-top:5px}
.sa-free-chip{padding:3px 9px;border-radius:5px;font-size:.74rem;font-weight:500;cursor:pointer;border:1.5px solid var(--bd);background:#fff;transition:all .15s;font-family:inherit}
.sa-free-chip:hover{border-color:var(--v);background:var(--vl)}.sa-free-chip.picked{border-color:var(--v);background:var(--v);color:#fff}
.sa-info{font-size:.76rem;color:var(--ts);line-height:1.5;margin-top:3px}
.as-table{width:100%;border-collapse:collapse;font-size:.78rem;margin-top:6px}
.as-table th,.as-table td{padding:6px 8px;border:1px solid #eef1f6;text-align:left}
.as-table thead th{background:#f1f5f9;font-weight:600;color:var(--ts)}.as-table tbody tr:hover{background:var(--vl)}
.btn-row-end{display:flex;gap:7px;flex-wrap:wrap;margin-top:12px;justify-content:flex-end}
.modal-bg{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);z-index:200;display:none;align-items:center;justify-content:center}
.modal-bg.show{display:flex}
.modal{background:#fff;border-radius:14px;padding:20px;width:95%;max-width:600px;box-shadow:var(--shl);position:relative;max-height:92vh;overflow-y:auto}
.modal h3{font-size:.92rem;font-weight:700;margin-bottom:10px}
.modal .close{position:absolute;right:14px;top:14px;cursor:pointer;font-size:1.1rem;color:var(--ts)}
.modal textarea{width:100%;height:100px;border:1.5px solid var(--bd);border-radius:8px;padding:8px;font-family:inherit;font-size:.8rem;resize:vertical;outline:none}.modal textarea:focus{border-color:var(--p)}
.wa-preview{background:#e5ddd5;border-radius:10px;padding:12px;margin:8px 0}
.wa-bubble{background:#dcf8c6;border-radius:8px;padding:9px 11px;display:inline-block;max-width:100%;white-space:pre-wrap;box-shadow:0 1px 2px rgba(0,0,0,.1);font-size:.78rem;line-height:1.55}
.copy-ok{color:var(--g);font-size:.76rem;font-weight:500;margin-left:6px;opacity:0;transition:opacity .3s}.copy-ok.show{opacity:1}
.wa-step{background:#f8fafc;border:1px solid var(--bd);border-radius:10px;padding:14px;margin-bottom:10px}
.wa-step-title{font-size:.82rem;font-weight:600;margin-bottom:8px;color:var(--pd)}
@media(max-width:700px){.hd h1{font-size:1.05rem}.cd{padding:12px}.tab{padding:6px 10px;font-size:.72rem}.stp{display:none}}
</style>
</head>
<body>
<div class="hd"><h1>📋 LPS 老師時間表查詢系統</h1><div class="sub">2025-2026 學年</div>
<div class="tabs"><button class="tab on" onclick="goTab(0)">🔄 調堂</button><button class="tab" onclick="goTab(1)">🕐 共同空堂</button><button class="tab" onclick="goTab(2)">📚 班別查詢</button><button class="tab" onclick="goTab(3)">🔀 代課安排</button></div></div>
<div class="wrap">
<div id="p0" class="pnl on">
  <div class="stp" id="s0s"><div class="st on"><span class="n">1</span>選老師</div><div class="st"><span class="n">2</span>選班別</div><div class="st"><span class="n">3</span>選日子</div><div class="st"><span class="n">4</span>結果</div></div>
  <div class="cd"><div class="ct">👩‍🏫 Step 1：選擇老師（至少兩位）</div><div class="chips" id="c0c"></div><div class="sb"><span class="ic">🔎</span><input id="c0q" placeholder="輸入老師姓名或代碼…" autocomplete="off"><div class="dd" id="c0d"></div></div></div>
  <div class="cd"><div class="ct">🏫 Step 2：選擇班別</div><div class="br" id="c0cls"></div></div>
  <div class="cd"><div class="ct">📅 Step 3：選擇日子</div><div class="br" id="c0day"></div></div>
  <div id="c0i"></div><div id="c0r"></div>
</div>
<div id="p1" class="pnl">
  <div class="stp" id="s1s"><div class="st on"><span class="n">1</span>選老師</div><div class="st"><span class="n">2</span>選日子</div><div class="st"><span class="n">3</span>結果</div></div>
  <div class="cd"><div class="ct">👩‍🏫 Step 1：選擇老師</div><div class="chips" id="c1c"></div><div class="sb"><span class="ic">🔎</span><input id="c1q" placeholder="輸入老師姓名或代碼…" autocomplete="off"><div class="dd" id="c1d"></div></div></div>
  <div class="cd"><div class="ct">📅 Step 2：選擇日子</div><div class="br" id="c1day"></div></div>
  <div id="c1i"></div><div id="c1r"></div>
</div>
<div id="p2" class="pnl">
  <div class="cd"><div class="ct">🔍 篩選條件</div><div class="fr">
    <div class="fg"><label>級別</label><select id="f2fm" onchange="onF2F()"><option value="">全部</option><option value="1">中一</option><option value="2">中二</option><option value="3">中三</option><option value="4">中四</option><option value="5">中五</option><option value="6">中六</option></select></div>
    <div class="fg"><label>班別</label><select id="f2cl"><option value="">全部</option></select></div>
    <div class="fg"><label>科目</label><select id="f2su"><option value="">全部</option></select></div>
    <div class="fg"><label>Day</label><select id="f2dy"><option value="">全部</option><option value="1">Day A</option><option value="2">Day B</option><option value="3">Day C</option><option value="4">Day D</option><option value="5">Day E</option><option value="6">Day F</option></select></div>
    <div class="fg"><label>節數</label><select id="f2pe"><option value="">全部</option><option value="1">P1</option><option value="2">P2</option><option value="3">P3</option><option value="4">P4</option><option value="5">P5</option><option value="6">P6</option><option value="7">P7</option><option value="8">P8</option></select></div>
    <button class="bp" onclick="doF2()">🔍 查詢</button></div></div>
  <div id="f2i"></div><div id="f2r"></div>
</div>
<div id="p3" class="pnl">
  <div class="sub-tabs"><div class="sub-tab on" onclick="goSub(0)">📌 按節數查空堂</div><div class="sub-tab" onclick="goSub(1)">👤 按缺席老師安排</div></div>
  <div id="sp0" class="sub-pnl on">
    <div class="stp" id="s3as"><div class="st on"><span class="n">1</span>選日子</div><div class="st"><span class="n">2</span>選節數</div><div class="st"><span class="n">3</span>結果</div></div>
    <div class="cd"><div class="ct">📅 Step 1：選擇日子</div><div class="br" id="s3a_day"></div></div>
    <div class="cd"><div class="ct">🔢 Step 2：選擇節數</div><div class="br" id="s3a_per"></div></div>
    <div id="s3a_i"></div><div id="s3a_r"></div></div>
  <div id="sp1" class="sub-pnl">
    <div class="stp" id="s3bs"><div class="st on"><span class="n">1</span>缺席老師</div><div class="st"><span class="n">2</span>選日子</div><div class="st"><span class="n">3</span>課堂</div><div class="st"><span class="n">4</span>代課</div><div class="st"><span class="n">5</span>儲存</div></div>
    <div class="cd"><div class="ct">👤 Step 1：缺席老師</div><div class="chips" id="c3bc"></div><div class="sb"><span class="ic">🔎</span><input id="c3bq" placeholder="輸入老師姓名或代碼…" autocomplete="off"><div class="dd" id="c3bd"></div></div></div>
    <div class="cd"><div class="ct">📅 Step 2：缺席日子</div><div class="br" id="s3b_day"></div></div>
    <div id="s3b_i"></div><div id="s3b_r"></div></div>
</div>
<!-- Modals -->
