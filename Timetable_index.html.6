function exportXls(){if(typeof XLSX==='undefined')return;let rows=[];s3b_t.forEach(at=>{for(let p=1;p<=8;p++){let k='D'+s3b_day+'P'+p,sl=at.schedule[k];if(sl&&(sl.cl||sl.su)){let a=subA[k];rows.push({'代課日子':DAYS[s3b_day-1],'節數':'第'+p+'節','班別':sl.cl||'—','科目':sC(sl.su),'缺席老師':at.chi+'('+at.short+')','代課老師':a?gtn(a):'未安排','課室':sl.rm||'—'})}}});let sc={};Object.values(subA).forEach(s=>{sc[s]=(sc[s]||0)+1});let sm=Object.entries(sc).map(([s,c])=>({'代課老師':gtn(s),'總代課節數':c}));let wb=XLSX.utils.book_new();XLSX.utils.book_append_sheet(wb,XLSX.utils.json_to_sheet(rows),'代課安排');if(sm.length)XLSX.utils.book_append_sheet(wb,XLSX.utils.json_to_sheet(sm),'代課統計');XLSX.writeFile(wb,'代課安排_'+DAYS[s3b_day-1]+'_'+new Date().toISOString().slice(0,10)+'.xlsx')}
function openEMdl(){let rows=[];s3b_t.forEach(at=>{for(let p=1;p<=8;p++){let k='D'+s3b_day+'P'+p,sl=at.schedule[k];if(sl&&(sl.cl||sl.su))rows.push({p:p,cls:sl.cl,su:sC(sl.su),absent:at.chi,sub:subA[k]?gtn(subA[k]):'未安排',room:sl.rm})}});let an=s3b_t.map(t=>t.chi).join('、');document.getElementById('emSub').value='代課通知 — '+DAYS[s3b_day-1]+' '+an+'缺席';let b='各位老師，\n\n以下是 '+DAYS[s3b_day-1]+' 的代課安排（'+an+' 缺席）：\n\n';rows.forEach(r=>{b+='第'+r.p+'節：'+(r.cls||'')+' '+r.su+' — 代課：'+r.sub+(r.room?' （室'+r.room+'）':'')+'\n'});b+='\n請各代課老師留意。謝謝！\n';document.getElementById('emBody').value=b;document.getElementById('emailModal').classList.add('show')}
function openWSub(){let rows=[];s3b_t.forEach(at=>{for(let p=1;p<=8;p++){let k='D'+s3b_day+'P'+p,sl=at.schedule[k];if(sl&&(sl.cl||sl.su))rows.push({p:p,cls:sl.cl,su:sC(sl.su),absent:at.chi,sub:subA[k]?gtn(subA[k]):'未安排',room:sl.rm})}});let an=s3b_t.map(t=>t.chi).join('、');let msg='📋 *LPS 代課安排通知*\n日子：*'+DAYS[s3b_day-1]+'*\n缺席：*'+an+'*\n\n';rows.forEach(r=>{msg+='▪️ P'+r.p+' | '+(r.cls||'')+' '+r.su+'\n　代課：'+r.sub+'\n'});msg+='\n請留意。謝謝！';window._waMsg=msg;let rh='<div class="wa-preview"><div class="wa-bubble">'+msg.replace(/\n/g,'<br>')+'</div></div><div style="display:flex;gap:6px;justify-content:flex-end;align-items:center;margin-top:6px"><span class="copy-ok" id="waCO">✅ 已複製</span><button class="tb" onclick="cpWA()">📋 複製</button><button class="bwa" onclick="snWA()">💬 WhatsApp</button></div>';document.getElementById('waModalBody').innerHTML=rh;document.getElementById('waModal').classList.add('show')}
function sendEmail(){let to=document.getElementById('emTo').value.trim();if(!to){alert('請輸入收件人');return}window.open('mailto:'+to+'?subject='+encodeURIComponent(document.getElementById('emSub').value)+'&body='+encodeURIComponent(document.getElementById('emBody').value),'_blank');closeModal('emailModal')}
function closeModal(id){document.getElementById(id).classList.remove('show')}
function goTab(i){document.querySelectorAll('.tab').forEach((b,j)=>b.classList.toggle('on',j===i));document.querySelectorAll('.pnl').forEach((p,j)=>p.classList.toggle('on',j===i))}
function goSub(i){document.querySelectorAll('.sub-tab').forEach((b,j)=>b.classList.toggle('on',j===i));document.querySelectorAll('.sub-pnl').forEach((p,j)=>p.classList.toggle('on',j===i))}
initT0();initT1();initT2();initS3A();initS3B();

</script>
